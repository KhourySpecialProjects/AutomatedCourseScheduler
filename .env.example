POSTGRES_USER=scheduler
POSTGRES_PASSWORD=scheduler
POSTGRES_DB=scheduler_db

# Optional: override just the host (defaults to "db" for Docker Compose).
# Set to "localhost" when running the backend outside Docker.
# POSTGRES_HOST=localhost

CORS_ORIGINS=http://localhost:3000

AUTH0_DOMAIN=your.domain.auth0.com
AUTH0_AUDIENCE=https://your.api.audience

# SPA client ID (same value as VITE_AUTH0_CLIENT_ID in frontend/.env)
# Used to build the signup /authorize URL sent to invited users.
AUTH0_SPA_CLIENT_ID=your_spa_client_id

# Base URL of the frontend app (used as the redirect after password change)
APP_BASE_URL=http://localhost:3000

# Frontend (Vite) — set these in frontend/.env
# VITE_AUTH0_DOMAIN=your.domain.auth0.com
# VITE_AUTH0_CLIENT_ID=your_spa_client_id_here
# VITE_AUTH0_AUDIENCE=https://your.audience.com
